@model ResetPasswordViewModel
@{
    ViewData["Title"] = "ResetPassword";
}


﻿    <!-- Page Header Start -->
<div class="container-fluid page-header mb-1 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Şifre Resetle</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">  <a class="text-body"> Üye değil misin?  </a> <a href="/Account/Register">Üye Ol!</a> </li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->
<div class="container-xxl">
    <div class="container">
        <div class="row g-5 align-items-center">

            <div class="col-6 offset-3">

                @if (TempData["success"] != null)
                {
                    <div class="alert alert-warning">
                        @TempData["success"]
                    </div>
                }
                <form asp-action="ResetPassword" asp-controller="Account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" name="userId" value="@Model.userId" />
                    <input type="hidden" name="token" value="@Model.token" />
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ReNewPassword" class="form-label"></label>
                        <input asp-for="ReNewPassword" class="form-control" />
                        <span asp-validation-for="ReNewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-success">Şifre Kaydet</button>
                    </div>
                    <div class="mb-3">
                        <a href="/Account/Register">Kayıt Ol</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>